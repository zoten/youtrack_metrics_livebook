# YouTrack API Configuration
# Required: Your YouTrack instance URL
YOUTRACK_BASE_URL=https://your-instance.youtrack.cloud

# Required: Permanent token for YouTrack API access
# Generate at: YouTrack → Profile → Hub Account → Authentication → New token
YOUTRACK_TOKEN=perm:your-token-here

# Optional: Base query (without time filter)
YOUTRACK_BASE_QUERY=project: MYPROJECT

# Optional: Number of days back to fetch (default: 90)
YOUTRACK_DAYS_BACK=90

# Optional: Filter issues by ID prefix (e.g., MYPROJ)
YOUTRACK_PROJECT_PREFIX=

# Optional: Custom field names (defaults shown)
YOUTRACK_STATE_FIELD=State
YOUTRACK_ASSIGNEES_FIELD=Assignee

# Optional: Comma-separated list of state names considered "In Progress"
YOUTRACK_IN_PROGRESS=In Progress

# Optional: Comma-separated inactive states for weekly report cycle-time start
# Cycle time starts when state transitions from these states (or no-state) to active work
YOUTRACK_REPORT_INACTIVE_STATES=To Do, Todo

# Optional: Comma-separated list of assignee logins to exclude from charts
YOUTRACK_EXCLUDED_LOGINS=

# Optional: Tag used to mark unplanned/interrupt work (default: "unplanned")
YOUTRACK_UNPLANNED_TAG=unplanned
